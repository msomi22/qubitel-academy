# Qubitel Academy Environment Variables
# Copy this file to .env and configure as needed

# Active Academy (tech, cbc, customer-experience)
# VITE_ACTIVE_ACADEMY=tech

# App Configuration
# VITE_APP_NAME=Qubitel Academy
# VITE_APP_TAGLINE=Focused learning and practice for every academy
# VITE_STORAGE_KEY=qubitel-academy

# Support Integration
# VITE_PAYPAL_ENABLED=true
# VITE_PAYPAL_SUPPORT_LINK=
# VITE_PAYPAL_HOSTED_BUTTON_ID=
# VITE_PAYPAL_CURRENCY=USD
# VITE_PAYSTACK_SUPPORT_LINK=

# Analytics (optional)
# VITE_ANALYTICS_ID=
